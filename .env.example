# Пример файла окружения для настройки параметров приложения.
# Скопируйте этот файл в .env и измените значения при необходимости.
# Параметры ОПЦИОНАЛЬНЫ, при отсутствии какого-либо параметра
# его значение устанавливается по умолчанию.

# Проект поддерживает разделение конфигурации по средам:
# - .env.development: настройки для локальной разработки (локальные API, отладочные флаги).
# - .env.testing: параметры для тестового окружения (тестовые API, моки).
# - .env.production: продакшен‑настройки (боевые API, оптимизированные флаги).

# Порядок настройки:
# 1. Решите, для какой среды вы настраиваете приложение.
# 2. Создайте копию этого файла с именем .env.<среда> (например, .env.production).
# 3. Внесите в новый файл все необходимые значения переменных.
# 4. В этом (или любом) файле убедитесь, что ENVIRONMENT соответствует выбранной среде.

# Примечание:
# Перед запуском приложения установите соответствующее значение переменной окружения ENVIRONMENT:
# например: ENVIRONMENT=development <запуск приложения>.
# Приложение читает переменные из файла, имя которого совпадает с текущим значением ENVIRONMENT.

# === Режим отладки ===
DEBUG=true|false

# === Настройки логирования ===
LOG_DIR=полный/путь/к/директории/логов
LOG_FILENAME=имя_файла.log
# Минимальный уровень логирования
MIN_LOG_LEVEL=DEBUG | INFO | WARNING | ERROR | CRITICAL

# === Реляционная база данных ===
# Поддерживаемые СУБД: sqlite.
DBMS=sqlite
DB_DIR=полный/путь/к/БД
DB_NAME=имя_БД.db