# Пример файла окружения для настройки параметров приложения.
# Скопируйте этот файл в .env и измените значения при необходимости.


# === Режим отладки ===
DEBUG=true|false

# === Настройки логирования ===
LOG_DIR=logs
LOG_FILENAME=app_log.log

# === Настройки RAG-системы ===
DOC_PATH=path/to/documents
EMBEDDING_MODEL=all-MiniLM-L6-v2
VECTOR_DB_NAME=docs

# === Настройки LLM ===
LLM_MODEL=llm_model